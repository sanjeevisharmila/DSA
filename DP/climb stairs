class Solution {
    static int[] dp;
    public int climbStairs(int n) {
         dp=new int[n+1];
        Arrays.fill(dp,-1);
        return fibnoci(n);
    }
     public int fibnoci(int n){
         if(n<=2)
        return n;
        if(dp[n]!=-1)
        return dp[n];
        dp[n]=fibnoci(n-1)+fibnoci(n-2);
        return dp[n];
    }
}

time=O(n

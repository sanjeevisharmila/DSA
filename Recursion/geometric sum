import java.util.*;
public class Main {
    public static void main(String args[]) {
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        double sum=0;
        for(int i=0;i<=n;i++){
           sum+=1/Math.pow(2,i);
        }
        System.out.println(sum);
    }   
}

time=O(n)
space=O(1)

import java.util.*;
public class Main {
    public static void main(String args[]) {
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        System.out.println(geometry(n));
    } 
    public static double geometry(int n){
        if(n==0)
        return 1;

        return 1/Math.pow(2,n)+geometry(n-1);
    }  
}

time=O(n)
space=O(n)

class Solution {
    public ArrayList<Integer> maxOfSubarrays(int[] arr, int k) {
        // code here
        ArrayList<Integer>ans=new ArrayList<>();
        int n=arr.length;
        for(int i=0;i<n;i++){
            int maxi=-1;
            for(int j=i;j<n;j++){
                maxi=Math.max(maxi,arr[j]);
                if(j-i+1==k){
                    ans.add(maxi);
                }
            }
        }
        return ans;
    }
}

time=O(n*n)
space=O(n)

